# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 数据库连接 - Transaction Pooler (应用使用)
# Supabase Dashboard → Settings → Database → Connection string → Transaction pooler
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres

# 数据库直连 (prisma migrate/db push)
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Mock AI mode - set to true to skip real AI calls and return simulated data (for development)
MOCK_AI=false

# AI Provider - set to: qwen | google | openai | anthropic | mistral
AI_PROVIDER=qwen

# 通义千问 Qwen-VL (阿里云 DashScope - 推荐，国内访问快，每月免费100万tokens)
# 注册: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=

# Google Gemini (free tier - 1500 req/day)
GOOGLE_GENERATIVE_AI_API_KEY=

# OpenAI (optional - $0.15/M input tokens)
OPENAI_API_KEY=

# Anthropic Claude (optional - $5 free credits for new users)
ANTHROPIC_API_KEY=

# Mistral Pixtral (optional - free experiment tier)
MISTRAL_API_KEY=
